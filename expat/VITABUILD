pkgname=expat
pkgver=2.6.2
pkgrel=1
url="https://libexpat.github.io/"
source=("https://github.com/libexpat/libexpat/releases/download/R_2_6_2/$pkgname-$pkgver.tar.xz")
sha256sums=('ee14b4c5d8908b1bec37ad937607eab183d4d9806a08adee472c3c3121d27364')

build() {
  cd $pkgname-$pkgver
  ./configure --host=arm-vita-eabi --prefix=$prefix --disable-shared --enable-static
  make -j$(nproc)
}

package () {
  cd $pkgname-$pkgver
  make DESTDIR=$pkgdir install
}
